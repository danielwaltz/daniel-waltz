{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "server: nuxt",
      "type": "node",
      "request": "launch",
      "outputCapture": "std",
      "program": "${workspaceFolder}/node_modules/nuxt/bin/nuxt.mjs",
      "args": ["dev"]
    },
    {
      "name": "client: browser",
      "type": "editor-browser",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/app"
    }
  ],
  "compounds": [
    {
      "name": "fullstack: nuxt",
      "configurations": ["server: nuxt", "client: browser"]
    }
  ]
}
